{
  "name": "json-eval-rs-react-native-monorepo",
  "version": "0.0.82",
  "private": true,
  "description": "JSON Eval RS React Native Bindings - Monorepo",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "yarn workspace @json-eval-rs/react-native prepare",
    "clean": "yarn workspace @json-eval-rs/react-native clean",
    "test": "yarn workspaces run test",
    "lint": "yarn workspaces run lint",
    "example:android": "yarn workspace rncli android",
    "example:ios": "yarn workspace rncli ios",
    "example:start": "yarn workspace rncli start",
    "example:pods": "yarn workspace rncli pods"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/byrizki/jsoneval-rs.git",
    "directory": "bindings/react-native"
  },
  "keywords": [
    "react-native",
    "json",
    "json-logic",
    "schema",
    "validation",
    "rust"
  ],
  "author": "Muhamad Rizki",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "fast-xml-parser": "^4.5.1",
    "flatted": "^3.3.1",
    "node-forge": "^1.3.1",
    "minimatch": "^9.0.5",
    "picomatch": "^4.0.1",
    "lodash": "^4.17.21",
    "brace-expansion": "^2.0.1",
    "yaml": "^2.4.5",
    "ajv": "^6.12.7"
  }
}
